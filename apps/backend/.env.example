# =====================================================
# JetApi Environment Configuration
# Copy this file to .env and fill in your values
# =====================================================

# ======================
# Core Settings
# ======================
PROJECT_NAME="JetApi"
APP_VERSION="1.0.0"
# Environment: dev | staging | prod
ENV=dev
DEBUG=false

# ======================
# Database Configuration
# ======================
# Supabase PostgreSQL:
#   DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Local PostgreSQL:
#   DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# SQLite (dev only):
#   DATABASE_URL=sqlite:///./jetapi.db
DATABASE_URL=sqlite:///./jetapi.db

# ======================
# Redis Configuration
# ======================
# Dev (Docker Compose): redis://redis:6379/0
# Prod (external managed): redis://user:password@redis-host:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# ======================
# Security - General
# ======================
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your-super-secret-key-change-this-in-production-must-be-32-chars

# ======================
# Authentication Settings
# ======================
ENABLE_LOCAL_AUTH=true
ENABLE_OAUTH2=false
OAUTH2_AUTO_PROVISION=true
OAUTH2_DEFAULT_ROLE=user
REQUIRE_EMAIL_VERIFICATION=false

# ======================
# JWT Settings
# ======================
# REQUIRED in production - separate from SECRET_KEY
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ======================
# OAuth2 Settings (External Providers)
# ======================
# Example for Google:
#   OAUTH2_ISSUER=https://accounts.google.com
#   OAUTH2_AUDIENCE=your-client-id.apps.googleusercontent.com
#   OAUTH2_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
OAUTH2_ISSUER=
OAUTH2_AUDIENCE=
OAUTH2_JWKS_URL=
OAUTH2_JWKS_JSON=

# ======================
# RBAC Settings
# ======================
ENABLE_RBAC=true

# ======================
# Password Policy
# ======================
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=false

# ======================
# Rate Limiting
# ======================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
AUTH_RATE_LIMIT_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW=300

# ======================
# Caching
# ======================
CACHE_ENABLED=true
CACHE_MAX_SIZE=1000
CACHE_DEFAULT_TTL=300

# ======================
# Background Jobs
# ======================
WORKER_COUNT=4
JOB_QUEUE_MAX_SIZE=10000

# ======================
# CORS Configuration
# ======================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ======================
# Email - General
# ======================
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=JetApi

# ======================
# Email - SMTP Provider
# ======================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
SMTP_SSL=false

# ======================
# Email - AWS SES Provider (API)
# ======================
AWS_SES_ENABLED=false
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_CONFIGURATION_SET=

# ======================
# Frontend URL
# ======================
FRONTEND_URL=http://localhost:3000
